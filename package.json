{
	"name": "imdbgraph",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vp dev",
		"build": "vp build",
		"preview": "vp preview",
		"start": "node .output/server/index.mjs",
		"check": "vp check",
		"test": "vp test run",
		"test:unit": "vp test run --project unit",
		"test:integration": "vp test run --project browser --project server",
		"test:db": "vp test run --project server",
		"test:browser": "vp test run --project browser",
		"test:update": "vp test run --project browser --update",
		"test:watch": "vp test --watch",
		"test:ui": "vp test dev --ui --open=false --api.port 5123 --api.strictPort --project browser",
		"e2e": "playwright test",
		"e2e:staging": "BASE_URL=https://imdbgraph.org playwright test",
		"e2e:update": "playwright test --update-snapshots",
		"report": "playwright show-report .playwright/report",
		"compose:up": "docker compose up -d --wait --remove-orphans postgres",
		"compose:down": "docker compose down",
		"compose:reset": "docker compose down --volumes --remove-orphans",
		"db:populate": "tsx scripts/populate-db.ts",
		"db:populate:local": "DATABASE_URL=postgres://imdbgraph_user:imdbgraph_test@localhost:5434/imdbgraph_test pnpm db:populate",
		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@aamini/config": "0.0.12",
		"@aamini/lib": "0.0.12",
		"@fontsource-variable/dm-sans": "^5.2.8",
		"@rolldown/plugin-babel": "^0.2.3",
		"@tanstack/react-devtools": "^0.10.2",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.166.7",
		"@tanstack/react-router-devtools": "^1.166.7",
		"@tanstack/react-router-ssr-query": "^1.166.7",
		"@tanstack/react-start": "^1.166.7",
		"@tanstack/router-plugin": "^1.166.7",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"lucide-react": "^1.8.0",
		"nitro": "latest",
		"posthog-js": "^1.369.1",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"recharts": "2.15.4",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/devtools-vite": "^0.6.0",
		"@testcontainers/postgresql": "^11.12.0",
		"@types/node": "^25.4.0",
		"@types/pg": "^8.18.0",
		"@types/pg-copy-streams": "^1.2.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vercel/functions": "^3.4.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/ui": "4.1.5",
		"babel-plugin-react-compiler": "^1.0.0",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"drizzle-seed": "^0.3.1",
		"msw": "^2.13.4",
		"pg": "^8.20.0",
		"pg-copy-streams": "^7.0.0",
		"playwright": "*",
		"tailwindcss": "^4.2.1",
		"testcontainers": "^11.12.0",
		"tsx": "^4.22.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "6.0.2",
		"vite": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:",
		"vitest-browser-react": "^2.0.5",
		"web-vitals": "^5.1.0",
		"zod": "^4.3.6"
	},
	"packageManager": "pnpm@11.1.2"
}
